  "shortcuts": [
    {
      "name": "New Deployment",
      "short_name": "Deploy",
      "description": "Create a new deployment",
      "url": "/deploy",
      "icons": [{ "src": "/shortcut-deploy.png", "sizes": "96x96" }]
    },
    {
      "name": "Projects",
      "short_name": "Projects",
      "description": "View all projects",
      "url": "/projects",
      "icons": [{ "src": "/shortcut-projects.png", "sizes": "96x96" }]
    },
    {
      "name": "Analytics",
      "short_name": "Analytics",
      "description": "View performance analytics",
      "url": "/analytics",
      "icons": [{ "src": "/shortcut-analytics.png", "sizes": "96x96" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "deployment_config",
          "accept": [".yml", ".yaml", ".json", ".config"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+clouddeploy",
      "url": "/deploy?config=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "prefer_related_applications": false,
  "related_applications": [],
  "iarc_rating_id": "",
  "dir": "ltr",
  "screenshots": [
