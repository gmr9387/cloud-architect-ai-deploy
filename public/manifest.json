{
  "name": "Cloud Deployment Platform",
  "short_name": "CloudDeploy",
  "description": "Professional cloud deployment and DevOps management platform",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#3b82f6",
  "background_color": "#0f172a",
